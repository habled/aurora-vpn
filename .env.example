# aurora vpn — environment variables.
# Copy this file to `.env` (without `.example`) and fill in the values.
# `.env` is gitignored and must NEVER be committed.
#
# On Render, you don't create a `.env` file — you paste each value into the
# Environment section of the dashboard. This file documents what they mean.

# ---------------------------------------------------------------------------
# REQUIRED
# ---------------------------------------------------------------------------

# Bot token from @BotFather. Long string like 7821234567:AAHxxxxxx...
BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to use /add and /stats.
# Find yours by messaging @userinfobot.
ADMIN_IDS=

# Full PostgreSQL connection string from Neon.tech or any other host.
# Example: postgresql://user:pass@host.region.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Public URL of your WebApp (the GitHub Pages site that serves index.html).
# MUST start with https://, include trailing slash.
# Example: https://habled.github.io/aurora-vpn/
WEBAPP_URL=

# Public URL of your Render service (the one running this bot).
# Render gives it to you after the first deploy.
# Example: https://aurora-vpn-bot.onrender.com
# MUST start with https://, no trailing slash.
PUBLIC_URL=

# The origin that's allowed to call the API from a browser.
# This is the GitHub Pages domain, WITHOUT path. Example: https://habled.github.io
# (different from WEBAPP_URL which contains the path)
CORS_ORIGIN=

# Random secret used to verify Telegram webhook requests.
# On Render, this is generated automatically via render.yaml — leave blank locally.
# If you want to set one manually, use a long random string (32+ chars).
WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# OPTIONAL
# ---------------------------------------------------------------------------

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Render injects PORT itself — don't set it in production.
# Set this only for local development.
# PORT=8080
